{
  "info": {
    "name": "Barber Shop API",
    "_postman_id": "barbershop-api-collection-v1",
    "description": "Barber Shop – Vizsgaremek API Collection\nBase URL: http://127.0.0.1/api\n\nHasználat:\n1. Futtasd a 'Login' kérést\n2. A token automatikusan bekerül a {{token}} változóba\n3. Az auth-igénylő kérések ezt használják Bearer tokenként",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1/api", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "barberId", "value": "1", "type": "string" },
    { "key": "bookingId", "value": "1", "type": "string" },
    { "key": "hairstyleId", "value": "1", "type": "string" },
    { "key": "galleryId", "value": "1", "type": "string" }
  ],
  "item": [
    {
      "name": "🏓 Ping",
      "item": [
        {
          "name": "Ping",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/ping", "host": ["{{baseUrl}}"], "path": ["ping"] }
          }
        }
      ]
    },
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Teszt Elek\",\n  \"email\": \"teszt@pelda.hu\",\n  \"password\": \"Secret123!\",\n  \"password_confirmation\": \"Secret123!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('Token mentve:', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@barbershop.hu\",\n  \"password\": \"Admin1234!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login (User)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@barbershop.hu\",\n  \"password\": \"User1234!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
          }
        },
        {
          "name": "Me (aktuális user)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "✂ Borbélyok",
      "item": [
        {
          "name": "Borbély lista (GET /barbers)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/barbers", "host": ["{{baseUrl}}"], "path": ["barbers"] }
          }
        },
        {
          "name": "Borbély részlet (GET /barbers/:id)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/barbers/{{barberId}}",
              "host": ["{{baseUrl}}"],
              "path": ["barbers", "{{barberId}}"]
            }
          }
        },
        {
          "name": "Következő szabad slot (GET /barbers/:id/next-slot)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/barbers/{{barberId}}/next-slot",
              "host": ["{{baseUrl}}"],
              "path": ["barbers", "{{barberId}}", "next-slot"]
            }
          }
        },
        {
          "name": "Borbély naptár (GET /barbers/:id/schedule)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/barbers/{{barberId}}/schedule?dateFrom=2026-02-24&dateTo=2026-03-02",
              "host": ["{{baseUrl}}"],
              "path": ["barbers", "{{barberId}}", "schedule"],
              "query": [
                { "key": "dateFrom", "value": "2026-02-24" },
                { "key": "dateTo", "value": "2026-03-02" }
              ]
            }
          }
        },
        {
          "name": "Borbély létrehozás [ADMIN] (POST /barbers)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Kovács Péter\",\n  \"specialization\": \"Skin Fade\",\n  \"bio\": \"10 éves tapasztalat, díjnyertes borbély.\",\n  \"photo_url\": \"https://via.placeholder.com/400x400?text=Kovacs+Peter\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/barbers", "host": ["{{baseUrl}}"], "path": ["barbers"] }
          }
        },
        {
          "name": "Borbély módosítás [ADMIN] (PUT /barbers/:id)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Kovács Péter\",\n  \"specialization\": \"Klasszikus + Fade\",\n  \"bio\": \"Frissített bemutatkozó szöveg.\",\n  \"photo_url\": \"https://via.placeholder.com/400x400?text=Updated\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/barbers/{{barberId}}",
              "host": ["{{baseUrl}}"],
              "path": ["barbers", "{{barberId}}"]
            }
          }
        },
        {
          "name": "Borbély törlés [ADMIN] (DELETE /barbers/:id)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/barbers/{{barberId}}",
              "host": ["{{baseUrl}}"],
              "path": ["barbers", "{{barberId}}"]
            }
          }
        }
      ]
    },
